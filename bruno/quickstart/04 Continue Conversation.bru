meta {
  name: 04 Continue Conversation
  type: http
  seq: 4
}

post {
  url: https://{{instanceId}}.{{proxyDomain}}/v1/responses
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{sessionId}}",
    "input": "Nice. What did I just ask you?"
  }
}

tests {
  test("continues the same thread", function () {
    expect(res.status).to.equal(200);
    expect(res.body.status).to.equal("completed");
    expect(res.body.session_id).to.equal(bru.getEnvVar("sessionId"));
    expect(res.body.output_text).to.be.a("string");
  });
}

docs {
  Follows up on the thread 03 Send Message started. The only difference from 03 is session_id:
  the gateway keeps the full history server-side, so you send just the new input, never the
  transcript. sessionId is set by 03's post-response script, so run 03 first. This follow-up
  deliberately asks the agent to recall the previous turn, which only works because the session
  carried it.

  Sending new input while a turn is still in flight on the same session returns 409 session_busy;
  an unknown session_id returns 404 session_not_found.
}
