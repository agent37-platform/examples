meta {
  name: 01 Create Instance
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/instances
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "name": "test-user",
    "template": "agent37-hermes",
    "resources": {
      "cpu": 2,
      "memory": 4,
      "disk": 6
    },
    "budget": {
      "topup_micros": 1000000,
      "monthly_cap_micros": 0
    },
    "user": "demo-user"
  }
}

script:post-response {
  if (res.status === 201 && res.body && res.body.id) {
    bru.setEnvVar("instanceId", res.body.id, { persist: true });
  }
}

tests {
  test("creates a running instance", function () {
    expect(res.status).to.equal(201);
    expect(res.body.id).to.be.a("string");
    expect(res.body.status).to.equal("running");
  });
}

docs {
  Spins up a fresh instance and saves its id to the instanceId env var (persisted), which every
  request after this one reuses. This is the control-plane call (api.agent37.com); the chat
  requests below go to the instance's own URL with the same sk_live_ key.
  
  The whole body is optional — POST an empty {} and you get the defaults. The fields it sends:
  
  - name — display name for the instance. Free-form.
  - template — which agent image to run. Defaults to agent37-hermes, the only system template.
    Workspace-owned custom templates are referenced by name here too; you never pass a raw image ref.
  - resources — cpu/memory must be one of the supported shapes: 2/4, 4/8, or 8/16 (vCPU / GB RAM).
    disk is a whole number of GB inside that shape's range — 6-20 for 2/4, 20-40 for 4/8, 40-80
    for 8/16. Omit resources to get the smallest shape (2 vCPU / 4 GB RAM / 6 GB disk). Bigger
    shapes cost more: compute is billed per hour against your wallet.
  - budget — managed LLM spend, in micros ($1 = 1,000,000). topup_micros is persistent headroom
    that funds chat — the $1 here covers this demo. monthly_cap_micros is an optional recurring
    monthly cap. Both default to 0, and at 0/0 the agent runs but every managed call is refused,
    so replies come back empty; set at least one.
  - user — optional free-form tag for the end user this instance belongs to (handy when your app
    makes one instance per user).
  
  status comes back "running" once the container is up, but the agent inside still needs a moment
  to boot — that's what 02 Wait for Ready checks. Creating an instance debits your prepaid
  workspace wallet for compute, so fund the wallet first (see README).
}
